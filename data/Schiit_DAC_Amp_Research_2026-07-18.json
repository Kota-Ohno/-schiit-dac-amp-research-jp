{
  "schema_version": "1.0",
  "snapshot_date": "2026-07-18",
  "locale": "ja-JP",
  "scope": "Schiit Audioの現行ヘッドホン・イヤホン向けDAC、アンプ、DAC/アンプ。米国公式サイトの販売状態と価格を基準とし、Lyr+ Last Callを別枠で含む。",
  "methodology": {
    "principles": [
      "価格、入出力、電力、電圧、保証などは公式製品ページを一次情報とした。",
      "測定レビュー、専門誌、フォーラムの複数系統を照合し、主観的な音質表現は事実と分離した。",
      "レビュー信頼度は好評価の強さではなく、世代一致、情報量、独立ソース数、長期使用情報の成熟度を表す。",
      "音質差はシステム、音量整合、個体、期待バイアスに左右される。DAC間の可聴差は断定しない。"
    ],
    "score_definitions": {
      "scale": "1（不向き）〜5（非常に向く）の編集評価。公式格付けではない。",
      "iem": {
        "1": "敏感な多BA型には避けたい",
        "2": "ノイズまたは出力インピーダンス面で限定的",
        "3": "低ゲインや出力選択で実用",
        "4": "低ノイズ・低インピーダンスで概ね安心",
        "5": "負ゲイン等を含め微小音量を扱いやすい"
      },
      "planar": {
        "1": "電力不足",
        "3": "一般的な平面駆動型には実用",
        "5": "大電流・高出力で余裕が大きい"
      },
      "high_z": {
        "1": "高インピーダンス型に不向き",
        "3": "実用",
        "5": "電圧余裕またはOTL適性が高い"
      },
      "value": {
        "1": "費用対効果を選びにくい",
        "3": "用途が合えば妥当",
        "5": "同価格帯で機能・性能が強い"
      }
    },
    "confidence_levels": {
      "High": "複数世代一致ソース、測定と長期傾向あり",
      "Medium": "複数ソースだが新製品または見解差あり",
      "Low": "発売直後で長期・独立レビューが少ない"
    }
  },
  "japan_100v": {
    "official_options": "公式の電圧選択は115Vまたは230Vで、日本100Vの定格保証は確認できない。",
    "recommendation": "内部電源機は購入前にSchiitへ100V運用可否を確認する。定格性能を重視する場合は、容量に余裕のある適切な100→115V昇圧トランスを安全基準に従って用いる。これは本調査の保守的提案であり公式指定ではない。",
    "regional_independent": [
      "Vestri",
      "Fulla E"
    ],
    "usb_power_limits": "Modi 5、Mimir、GunnrはUSB給電できるが、AC給電時よりライン出力または最大ヘッドホン出力が低下する。",
    "official_url": "https://www.schiit.com/voltage-type"
  },
